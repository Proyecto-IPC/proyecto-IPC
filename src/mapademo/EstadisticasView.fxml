<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<ScrollPane fitToWidth="true" stylesheets="@/resources/style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="mapademo.EstadisticasViewController">

    <VBox spacing="24" styleClass="home-page">

        <!-- CABECERA -->
        <VBox spacing="4">
            <Label text="Estadísticas" styleClass="page-title"/>
            <Label text="Resumen acumulado de todas tus actividades."
                   styleClass="muted-label" wrapText="true"/>
        </VBox>

        <!-- TARJETAS DE MÉTRICAS -->
        <GridPane fx:id="statsGrid" hgap="12" vgap="12"/>

        <!-- GRÁFICA KM POR SEMANA -->
        <VBox spacing="8" styleClass="detail-block">
            <Label text="Kilómetros por semana" styleClass="section-title"/>
            <BarChart fx:id="barChartKm" legendVisible="false"
                      prefHeight="220" animated="false">
                <xAxis><CategoryAxis label="Semana"/></xAxis>
                <yAxis><NumberAxis label="km"/></yAxis>
            </BarChart>
        </VBox>

        <!-- GRÁFICA DESNIVEL -->
        <VBox spacing="8" styleClass="detail-block">
            <Label text="Desnivel acumulado" styleClass="section-title"/>
            <LineChart fx:id="lineChartDesnivel" legendVisible="false"
                       prefHeight="220" animated="false">
                <xAxis><CategoryAxis label="Actividad"/></xAxis>
                <yAxis><NumberAxis label="m"/></yAxis>
            </LineChart>
        </VBox>

    </VBox>
</ScrollPane>