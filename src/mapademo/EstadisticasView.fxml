<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.ActividadesViewController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <Label text="Gestión de Actividades" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    
    <ListView fx:id="activityList" VBox.vgrow="ALWAYS" />
    
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="btnImportar" onAction="#handleImportar" prefHeight="40.0" prefWidth="150.0" 
                text="Importar GPX" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
    </HBox>
</VBox>