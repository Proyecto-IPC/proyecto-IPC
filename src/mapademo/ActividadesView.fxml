<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@/resources/style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="mapademo.ActividadesViewController">

    <VBox spacing="20" styleClass="home-page">

        <!-- CABECERA -->
        <VBox spacing="4">
            <Label text="Actividades" styleClass="page-title"/>
            <Label text="Tus rutas importadas desde archivos GPX."
                   styleClass="muted-label" wrapText="true"/>
        </VBox>

        <!-- BOTÓN IMPORTAR -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="btnImportar" text="＋ Importar GPX"
                    onAction="#handleImportar" styleClass="btn-primary"/>
            <Label fx:id="lblEstado" styleClass="muted-label"/>
        </HBox>

        <!-- LISTA DE ACTIVIDADES -->
        <VBox fx:id="listaActividades" spacing="12"/>

        <!-- ESTADO VACÍO -->
        <VBox fx:id="emptyState" spacing="8" alignment="CENTER_LEFT"
              styleClass="home-empty-state">
            <Label text="Sin actividades" styleClass="empty-state-title"/>
            <Label text="Importa un archivo GPX para ver tus rutas aquí."
                   styleClass="empty-state-text" wrapText="true"/>
        </VBox>

    </VBox>
</ScrollPane>