<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="650.0" prefWidth="1000.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.MainViewController">
   <top>
      <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="16.0" styleClass="shell-topbar">
         <children>
            <VBox spacing="2.0">
               <children>
                  <Label fx:id="lblTopTitle" styleClass="shell-title" text="Dashboard" />
                  <Label fx:id="lblTopContext" styleClass="shell-context" text="Resumen del club y actividad reciente" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnImportar" disable="true" mnemonicParsing="false" styleClass="outline-button" text="Importar actividad" />
         </children>
      </HBox>
   </top>
   <left>
      <VBox fx:id="sideBar" spacing="6.0" styleClass="shell-sidebar">
         <children>
            <VBox spacing="2.0" styleClass="shell-brand">
               <children>
                  <Label styleClass="shell-brand-title" text="Running La Safor" />
                  <Label styleClass="shell-brand-subtitle" text="Club de running" />
               </children>
            </VBox>
            <Button fx:id="btnDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDashboard" styleClass="nav-button" text="Dashboard" />
            <Button fx:id="btnMapa" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMapa" styleClass="nav-button" text="Mapa" />
            <Button fx:id="btnPerfil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handlePerfil" styleClass="nav-button" text="Perfil" />
            <Button fx:id="btnHistorial" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleHistorial" styleClass="nav-button" text="Historial" />
         </children>
      </VBox>
   </left>
</BorderPane>
