                                    <ImageView fx:id="mapImageView" fitHeight="700.0" fitWidth="900.0" pickOnBounds="true" preserveRatio="true" />
                                 </children>
                              </Pane>
                           </children>
                        </Group>
                     </children>
                  </Group>
               </content>
