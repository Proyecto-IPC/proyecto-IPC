<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="profile-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.ProfileViewController">
   <children>
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER_LEFT" maxWidth="420.0" spacing="14.0" styleClass="profile-card">
               <children>
                  <Label styleClass="page-title" text="Mi perfil" />
                  <Label styleClass="muted-label" text="Datos de la cuenta activa" />
                  <VBox maxWidth="1.7976931348623157E308" styleClass="field-stack">
                     <children>
                        <Label styleClass="field-label" text="Usuario" />
                        <Label fx:id="lblUsuario" styleClass="profile-value" text="No disponible" />
                     </children>
                  </VBox>
                  <VBox maxWidth="1.7976931348623157E308" styleClass="field-stack">
                     <children>
                        <Label styleClass="field-label" text="Correo electrónico" />
                        <Label fx:id="lblEmail" styleClass="profile-value" text="No disponible" />
                     </children>
                  </VBox>
                  <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout" styleClass="button-secundario" text="Cerrar sesión">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
