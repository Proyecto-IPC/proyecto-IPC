<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>


<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="mapademo.RegisterViewController">
   <children>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Crear Cuenta" />
            <TextField fx:id="txtUsuario" promptText="Nombre de usuario" />
            <PasswordField fx:id="txtPassword" promptText="Contraseña" />
            <PasswordField fx:id="txtConfirm" promptText="Confirmar Contraseña" />
            <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#handleRegistro" text="Registrarse" />
            <Label text="Ya tienes cuenta?" />
            <Button fx:id="btnIrLogin" mnemonicParsing="false" text="Inicia Sesión" />
            <Label fx:id="lblError" />
         </children>
      </VBox>
   </children>
</AnchorPane>
