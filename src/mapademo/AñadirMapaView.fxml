<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" stylesheets="@../resources/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.AñadirMapaViewController">
   <content>
      <VBox alignment="CENTER" minHeight="520.0" spacing="22.0" styleClass="home-page">
         <children>
            <VBox alignment="CENTER_LEFT" maxWidth="760.0" spacing="16.0" styleClass="map-form-card">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="page-title" text="Añadir nuevo mapa" />
                              <Label styleClass="muted-label" text="Selecciona una imagen y define las coordenadas de sus bordes." />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox spacing="24.0">
                     <children>
                        <VBox minWidth="310.0" spacing="12.0" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox styleClass="field-stack">
                                 <children>
                                    <Label styleClass="field-label" text="Nombre" />
                                    <TextField fx:id="txtNombreMapa" promptText="Nombre del mapa" />
                                 </children>
                              </VBox>

                              <VBox styleClass="field-stack">
                                 <children>
                                    <Label styleClass="field-label" text="Seleccionar archivo" />
                                    <HBox spacing="8.0">
                                       <children>
                                          <TextField fx:id="txtRutaImagen" editable="false" promptText="Sin imagen seleccionada" HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnExaminar" mnemonicParsing="false" onAction="#handleSeleccionarImagen" styleClass="primary-button" text="Examinar" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>

                              <StackPane minHeight="190.0" prefHeight="190.0" maxHeight="190.0" styleClass="map-image-preview">
                                 <children>
                                    <Label fx:id="lblPreviewPlaceholder" styleClass="muted-label" text="Preview del mapa" />
                                    <ImageView fx:id="mapPreview" fitHeight="190.0" fitWidth="310.0" preserveRatio="true" visible="false" />
                                 </children>
                              </StackPane>

                              <Label fx:id="lblFeedback" minHeight="28.0" styleClass="error" text=" " wrapText="true" />
                           </children>
                        </VBox>

                        <VBox minHeight="275.0" prefHeight="275.0" maxHeight="275.0" spacing="0.0" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox spacing="12.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="field-label" text="Latitud mínima" />
                                          <TextField fx:id="txtLatSur" maxWidth="1.7976931348623157E308" promptText="Ej: 39.33" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="field-label" text="Latitud máxima" />
                                          <TextField fx:id="txtLatNorte" maxWidth="1.7976931348623157E308" promptText="Ej: 39.87" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>

                              <Region VBox.vgrow="ALWAYS" />

                              <VBox spacing="12.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="field-label" text="Longitud mínima" />
                                          <TextField fx:id="txtLonOeste" maxWidth="1.7976931348623157E308" promptText="Ej: -0.50" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="field-label" text="Longitud máxima" />
                                          <TextField fx:id="txtLonEste" maxWidth="1.7976931348623157E308" promptText="Ej: 0.11" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>

                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button fx:id="btnCancelar" cancelButton="true" minWidth="130.0" mnemonicParsing="false" onAction="#handleBotonCancelar" styleClass="secondary-button" text="Cancelar" />
                        <Button fx:id="btnAñadir" defaultButton="true" minWidth="130.0" mnemonicParsing="false" onAction="#handleBotonAñadir" styleClass="primary-button" text="Añadir" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
