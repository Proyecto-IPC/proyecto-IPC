<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.LoginViewController">
   <children>
      <!-- LADO IZQUIERDO: Nombre + imagen -->
      <VBox alignment="CENTER" spacing="20" styleClass="panel-izquierdo" HBox.hgrow="ALWAYS">
         <children>
            <Label styleClass="titulo-app" text="Running La Safor" />
            <ImageView fitHeight="200" fitWidth="200" preserveRatio="true" />
         </children>
      </VBox>

      <!-- LADO DERECHO: Formulario de login -->
      <VBox alignment="CENTER" fillWidth="false" spacing="15" styleClass="panel-derecho" HBox.hgrow="ALWAYS">
         <children>
            <Label styleClass="titulo" text="Iniciar Sesión" />
            <TextField fx:id="txtUsuario" maxWidth="300" promptText="Usuario" />
            <PasswordField fx:id="txtPassword" maxWidth="300" promptText="Contraseña" />
            <Button fx:id="btnLogin" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" text="Entrar" />
            <Label text="¿No tienes cuenta?" />
            <Button fx:id="btnIrRegistro" mnemonicParsing="false" onAction="#handleIrRegistro" styleClass="button-secundario" text="Registrarme" />
            <Label fx:id="lblError" styleClass="error" text=" " />
         </children>
      </VBox>
   </children>
</HBox>